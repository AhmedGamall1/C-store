# ============================================================
# C-Store environment configuration
# ============================================================
# Copy this file to `.env` and fill in values:
#     cp .env.example .env
#
# Rules:
#   - All values are STRINGS. Do NOT wrap them in quotes.
#   - `.env` is gitignored. Never commit it.
#   - On the production server, this same `.env` lives at the repo
#     root with prod values; it is not transferred from your machine.
# ============================================================


# ---- Runtime ------------------------------------------------------
NODE_ENV=development               # development | test | production
PORT=5000                          # internal server HTTP port


# ---- Public origin of the client ----------------------------------
# Used by the server's CORS allowlist. Must match the URL the browser
# actually loads from (no trailing slash).
#   dev:  http://localhost:5173
#   prod: https://yourdomain.com
CLIENT_URL=http://localhost:5173


# ---- Database (read by the server) --------------------------------
# Full Postgres connection string used by Prisma.
#   dev:  postgresql://cstore:CHANGEME@localhost:5432/cstore
#   prod: postgresql://cstore:CHANGEME@postgres:5432/cstore
#         (host is the compose service name, not localhost)
DATABASE_URL=


# ---- Database (read by docker-compose, NOT the app) ---------------
# These are used to provision the postgres container. The credentials
# here MUST match the ones inside DATABASE_URL above.
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=5432                       # host port for dev compose only


# ---- Redis (read by docker-compose) -------------------------------
REDIS_PORT=6379                    # host port for dev compose only
REDIS_URL=                         # reserved — not yet used by the server


# ---- Auth (server) ------------------------------------------------
# JWT_SECRET MUST be at least 32 characters. Generate a fresh one:
#     node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d


# ---- Cloudinary (server) ------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ---- Paymob (server) ----------------------------------------------
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=


# ---- Production deploy (read by docker-compose.prod.yml + Caddy) --
# Only required when running the prod stack on the VPS.
# DOMAIN must be a real domain whose A record points at the server's
# public IP — Caddy uses it to provision a Let's Encrypt certificate.
DOMAIN=yourdomain.com
ACME_EMAIL=


# ---- Client build (read by Vite at BUILD TIME) --------------------
# WARNING: any variable prefixed with VITE_ is INLINED into the
# client JavaScript bundle and shipped to every browser. Never put
# secrets behind a VITE_ prefix.
#
# Default `/api` works for both dev (Vite proxies to :5000) and prod
# (Caddy serves the API on the same origin). Override only if your
# client and API live on different origins.
VITE_API_URL=/api